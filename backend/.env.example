# REQUIRED: Gemini API Key for document analysis and RAG functionality
# Obtain from: https://ai.google.dev
# Without this key, the backend will fail to start
GEMINI_API_KEY=your_gemini_api_key

AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1
S3_BUCKET_NAME=legal-docs-temp
DYNAMODB_TABLE_DOCUMENTS=Documents
DYNAMODB_TABLE_CHATS=ChatSessions
JWT_SECRET=your_jwt_secret
PORT=8000

# CORS: Frontend URL for production cross-origin requests
# Required for the backend to accept requests from your deployed frontend
# Example: https://nyayavanni.vercel.app
FRONTEND_URL=http://localhost:5173
