# ============================================================
# NyayaVanni — Environment Variables Example
# ============================================================
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env
#
# ⚠️  Never commit your real .env file to version control.
# ============================================================


# ------------------------------------------------------------
# BACKEND (FastAPI)
# ------------------------------------------------------------

# Google Generative AI (Gemini) API key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Host and port for the FastAPI backend server
# Default: http://localhost:8000
BACKEND_HOST=localhost
BACKEND_PORT=8000

# Allowed origins for CORS (comma-separated)
# Example: http://localhost:5173,https://your-production-domain.com
ALLOWED_ORIGINS=http://localhost:5173

# Max upload file size in bytes (default: 10MB)
MAX_UPLOAD_SIZE=10485760


# ------------------------------------------------------------
# FRONTEND (React + Vite)
# ------------------------------------------------------------

# Backend API base URL — must match where your FastAPI server is running
VITE_API_URL=http://localhost:8000

# App environment: development | production
VITE_APP_ENV=development
