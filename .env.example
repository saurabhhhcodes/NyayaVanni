# ============================================================
# NyayaVanni — Environment Variables Example
# ============================================================
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env
#
# ⚠️  Never commit your real .env file to version control.
# ============================================================

# ------------------------------------------------------------
# BACKEND (FastAPI)
# ------------------------------------------------------------

# Google Generative AI (Gemini) API key — REQUIRED
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model name (default: gemini-2.0-flash-001)
# See https://ai.google.dev/gemini-api/docs/models for available models
GEMINI_MODEL_NAME=gemini-2.0-flash-001

# Host and port for the FastAPI backend server
BACKEND_HOST=localhost
BACKEND_PORT=8000

# Frontend URL for CORS — must match your frontend origin
# Development: http://localhost:5173
# Production: https://your-production-domain.com
FRONTEND_URL=http://localhost:5173

# Allowed origins for CORS (comma-separated, legacy fallback)
ALLOWED_ORIGINS=http://localhost:5173

# Session cookie secure flag — set to true in production with HTTPS
SESSION_COOKIE_SECURE=false

# Max upload file size in bytes (default: 10 MB)
MAX_UPLOAD_SIZE=10485760

# ------------------------------------------------------------
# EMAIL (SMTP) for account verification and notifications
# If not configured, verification emails are logged to console.
# ------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ------------------------------------------------------------
# RATE LIMITING (backend)
# ------------------------------------------------------------
# Format: "number/period" — e.g. "100/hour", "10/minute"

# Global rate limit across all endpoints
GLOBAL_RATE_LIMIT=100/hour

# File upload endpoint
UPLOAD_RATE_LIMIT=10/minute

# Document analysis endpoint
ANALYZE_RATE_LIMIT=5/minute

# Document chat endpoint
CHAT_RATE_LIMIT=20/minute

# General chat endpoint
GENERAL_CHAT_RATE_LIMIT=30/minute

# Per-route overrides (used in api/routes.py)
RATE_LIMIT_ANALYZE=10/minute
RATE_LIMIT_CHAT=30/minute

# ------------------------------------------------------------
# FRONTEND (React + Vite)
# ------------------------------------------------------------

# Backend API base URL — must match where FastAPI is running
VITE_API_URL=http://localhost:8000

# App environment: development | production
VITE_APP_ENV=development
